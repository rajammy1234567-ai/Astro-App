# =============================================================================
# ASTRO USER APP — Mobile Environment
# Copy: cp .env.example .env
# Or run from root: npm run setup:env
# =============================================================================

# Live backend (Render) — used by Expo Go + APK
EXPO_PUBLIC_API_URL=https://astro-app-ru1d.onrender.com/api
EXPO_PUBLIC_FORCE_REMOTE=1

# Local only (phone + PC same WiFi, server running on PC):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5000/api
# EXPO_PUBLIC_FORCE_REMOTE=0

# EAS Build project ID (run: npx eas init in this folder)
# EAS_PROJECT_ID=your-eas-project-id
