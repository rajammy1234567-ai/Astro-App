# =============================================================================
# ASTRO USER APP — Mobile Environment
# Copy: cp .env.example .env
# Or run from root: npm run setup:env
# =============================================================================

# Development (phone + PC same WiFi) — auto-detected if left as localhost
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Production (Play Store build) — set your live server URL:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api

# EAS Build project ID (run: npx eas init in this folder)
# EAS_PROJECT_ID=your-eas-project-id