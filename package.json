{
  "name": "astro-app-monorepo",

  "version": "1.0.0",
  
  "private": true,
  "description": "AstroTalk — 1 backend, 3 Play Store apps (User, Admin, Astro)",
  "scripts": {
    "setup:env": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-mobile-env.ps1",
    "server": "cd server && npm run dev",
    "server:start": "cd server && npm start",
    "user:dev": "cd user-panel && npm run dev",
    "user:android": "cd user-panel && npm run android",
    "user:apk": "cd user-panel && npm run build:apk",
    "user:playstore": "cd user-panel && npm run build:playstore",
    "admin:dev": "cd admin-app && npm run dev",
    "admin:android": "cd admin-app && npm run android",
    "admin:apk": "cd admin-app && npm run build:apk",
    "admin:playstore": "cd admin-app && npm run build:playstore",
    "astro:dev": "cd astro-app && npm run start",
    "astro:android": "cd astro-app && npm run android",
    "astro:apk": "cd astro-app && npm run build:apk",
    "astro:playstore": "cd astro-app && npm run build:playstore",
    "install:all": "cd server && npm install && cd ../user-panel && npm install && cd ../admin-app && npm install && cd ../astro-app && npm install"
  }
}
