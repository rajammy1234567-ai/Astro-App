# Normalize line endings — stops endless "LF will be replaced by CRLF" noise on Windows
* text=auto

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep lockfiles stable
package-lock.json text eol=lf
*.json text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary
*.apk binary
*.aab binary
