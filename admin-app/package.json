{
  "name": "astro-admin-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "node ../shared/block-onedrive.js expo start --host lan --port 8082",
    "fresh": "node ../shared/block-onedrive.js expo start -c --clear --host lan --port 8082",
    "phone": "node ../shared/block-onedrive.js expo start -c --clear --host lan --port 8082",
    "tunnel": "node ../shared/block-onedrive.js expo start --host tunnel -c --port 8082",
    "dev": "node ../shared/block-onedrive.js expo start --host lan --port 8082",
    "android": "node ../shared/block-onedrive.js expo start --android --host lan --port 8082",
    "ios": "expo start --ios --host lan --port 8082",
    "build:apk": "eas build --platform android --profile apk --clear-cache",
    "build:apk:preview": "eas build --platform android --profile preview --clear-cache",
    "build:playstore": "eas build --platform android --profile production",
    "postinstall": "node scripts/patch-metro-onedrive.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.18.1",
    "babel-preset-expo": "~57.0.0",
    "expo": "~57.0.6",
    "expo-build-properties": "~57.0.5",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.4",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "react-refresh": "^0.18.0",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  }
}
