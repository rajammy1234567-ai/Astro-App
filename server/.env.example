# =============================================================================
# ASTRO APP ‚Äî SERVER ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED ‚Äî App won't work without these
# -----------------------------------------------------------------------------

# Secret key for JWT tokens (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server port
PORT=5000

# development | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE ‚Äî Choose ONE option
# -----------------------------------------------------------------------------

# false = try Atlas ‚Üí local Mongo ‚Üí disk DB (server/.data/mongo) ‚Äî data PERSISTS
USE_MEMORY_DB=false

# Cloud MongoDB (optional ‚Äî whitelist your IP in Atlas Network Access)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/astro-app

# Local MongoDB install (optional fallback)
# LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/astro-app

# First install demo data (products/blogs). Set false to start empty.
SEED_DEMO_DATA=true

# -----------------------------------------------------------------------------
# GMAIL OTP ‚Äî Required for real email OTP on login/signup
# -----------------------------------------------------------------------------
# How to get Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" ‚Üí Create ‚Üí Select "Mail" ‚Üí Copy 16-char password
#   4. Paste below as SMTP_PASS (no spaces)

SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
SMTP_FROM=your.email@gmail.com

# OTP validity in minutes (default: 10)
OTP_EXPIRY_MINUTES=10

# App name shown in email subject
APP_NAME=Astrotalk

# -----------------------------------------------------------------------------
# DEV FALLBACK ‚Äî Used when Gmail SMTP is NOT configured
# -----------------------------------------------------------------------------
# Phone login always uses this in dev. Email uses this only if SMTP not set.
DEV_OTP=123456

# -----------------------------------------------------------------------------
# ADMIN PANEL ‚Äî Auto-seeded on first server start
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@astrotalk.com
ADMIN_PASSWORD=admin123

# ASTRO PANEL ‚Äî Astrologer partner app link sent to selected users
ASTRO_PANEL_URL=astro-app://login

# Seeded approved astrologers (via admin application flow)
# User app shows only isPublished + approvedViaApplication astrologers
# Panel login: 9876543210 / astro123

# -----------------------------------------------------------------------------
# OPTIONAL ‚Äî Agora Voice/Video Call (https://console.agora.io)
# Project ‚Üí App ID + Primary Certificate (enable certificate in console)
# Expo Go mein call NAHI chalegi ‚Äî dev build / APK chahiye
# -----------------------------------------------------------------------------
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# -----------------------------------------------------------------------------
# OPTIONAL ‚Äî Payment (Razorpay)
# Leave empty for dev mode (wallet credits directly without payment)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL ‚Äî Image uploads (Cloudinary)
# Leave empty if not using image upload feature
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# -----------------------------------------------------------------------------
# OPTIONAL ó AstrologyAPI.com (Janam Kundli, Panchang, Match, Dasha, Dosha)
# Free key from https://astrologyapi.com ó keep server-side only
# -----------------------------------------------------------------------------
ASTROLOGY_API_KEY=
ASTROLOGY_API_BASE=https://json.astrologyapi.com/v1
