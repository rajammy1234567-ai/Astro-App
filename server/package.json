{
  "name": "astro-app-server",
  "version": "1.0.0",
  "description": "Astro App Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo \"No compile step — pure Node API\"",
    "seed": "node -e \"require('dotenv').config(); const connectDB=require('./config/db'); const seed=require('./utils/seedData'); connectDB().then(seed).then(()=>process.exit(0))\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "agora-token": "^2.0.5",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "nodemailer": "^9.0.1",
    "razorpay": "^2.9.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.9"
  }
}
